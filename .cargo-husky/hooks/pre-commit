#!/bin/sh
# cargo-husky pre-commit hook
# Runs formatting and linting checks before committing

set -e

echo "🔍 Running pre-commit checks..."

# Check formatting
echo "  → Checking code formatting..."
if ! cargo fmt --all -- --check; then
    echo "❌ Formatting check failed. Run 'cargo fmt' or 'make fmt' to fix."
    exit 1
fi

# Run clippy (lighter check - only workspace libs, no tests/benches)
echo "  → Running clippy..."
if ! cargo clippy --workspace --lib -- -D warnings; then
    # If clippy fails with build errors, try cleaning and retry once
    echo "  → Build error detected, cleaning and retrying..."
    cargo clean
    if ! cargo clippy --workspace --lib -- -D warnings; then
        echo "❌ Clippy check failed. Fix warnings or run 'make lint-fix' to auto-fix."
        echo "   If build errors persist, run 'cargo clean' manually."
        exit 1
    fi
fi

echo "✅ Pre-commit checks passed!"
