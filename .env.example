# Aura LLM Gateway Environment Configuration

# Database Configuration
# Use 127.0.0.1 instead of localhost to force IPv4
# Port 5433 matches the docker-compose postgres port mapping
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/aura?sslmode=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
AURA_HOST=0.0.0.0
AURA_PORT=8080

# Logging
RUST_LOG=info,aura_proxy=debug

# Admin API Key (change in production!)
AURA_ADMIN_KEY=admin-dev-key

# Aura API Key (for making requests to the gateway)
AURA_API_KEY=aura_***

# Master encryption key for encrypting provider credentials (32 bytes hex)
# Generate with: openssl rand -hex 32
AURA_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

