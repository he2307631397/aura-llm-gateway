# Aura LLM Gateway Environment Configuration

# Database Configuration
# Use 127.0.0.1 instead of localhost to force IPv4
# Port 5433 matches the docker-compose postgres port mapping
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/aura?sslmode=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
AURA_HOST=0.0.0.0
AURA_PORT=8080

# CORS — comma-separated list of allowed Origin headers for cross-origin requests.
# Required in production (e.g. when the playground frontend hits the API from
# a different domain). Leave UNSET in local dev to allow any origin.
# Example: AURA_CORS_ALLOWED_ORIGINS=https://playground.aura-llm.dev,https://aura-llm.dev
AURA_CORS_ALLOWED_ORIGINS=

# Logging
RUST_LOG=info,aura_proxy=debug

# Admin API Key (change in production!)
AURA_ADMIN_KEY=admin-dev-key

# Aura API Key (for making requests to the gateway)
AURA_API_KEY=aura_***

# Master encryption key for encrypting provider credentials (32 bytes hex)
# Generate with: openssl rand -hex 32
AURA_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Mistral AI (https://console.mistral.ai/api-keys/)
MISTRAL_API_KEY=

# HuggingFace TGI — per-deployment endpoint (Inference Endpoints)
# Both key and endpoint URL are required to enable this provider
HUGGINGFACE_API_KEY=
HUGGINGFACE_ENDPOINT_URL=https://your-endpoint.endpoints.huggingface.cloud
# Optional: model name served at this endpoint (for routing purposes)
HUGGINGFACE_MODEL=

# Ollama — local inference server (no API key required)
# Defaults to http://localhost:11434 if not set
OLLAMA_BASE_URL=http://localhost:11434

# AWS Bedrock — uses the standard AWS credential chain
# Set AWS_REGION to enable; credentials come from env vars, ~/.aws, or IAM role
AWS_REGION=us-east-1
# Optional: explicit static credentials (prefer IAM role / ~/.aws/credentials in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

