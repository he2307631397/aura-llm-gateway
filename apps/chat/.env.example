# Aura LLM Gateway — Chat App Configuration
# Copy this file to .env for local development.
#
# IMPORTANT: In production (Vercel), the chat app does NOT hold a gateway
# API key. It calls /api/proxy/* (a serverless function) which holds the
# user's per-session key server-side. This file only matters for local dev.

# ============================================================================
# Local dev configuration
# ============================================================================

# Where the gateway runs locally. The Vite dev server will fetch directly
# here instead of going through the /api/proxy serverless function. To test
# the full auth + proxy flow locally, run `vercel dev` instead of `npm run
# dev` — vercel dev mounts the serverless functions and you can leave this
# unset.
VITE_API_BASE_URL=http://localhost:8080

# Tavily API key for web search tool (optional, for agent mode)
# Get from: https://tavily.com
# VITE_TAVILY_API_KEY=tvly-xxxxxxxxxxxxx

# ============================================================================
# Server-side env vars (NOT prefixed with VITE_; never sent to the browser)
# ============================================================================
# These are read by the Vercel serverless functions in apps/chat/api/. In
# production, set them in the Vercel dashboard's Environment Variables panel.
# For local dev with `vercel dev`, put them here.

# better-auth signing secret. Generate with: openssl rand -hex 32
# BETTER_AUTH_SECRET=...

# GitHub OAuth app credentials.
# Create the app at https://github.com/settings/developers
# Callback URL: https://playground.aura-llm.dev/api/auth/callback/github
# GITHUB_CLIENT_ID=Ov23li...
# GITHUB_CLIENT_SECRET=...

# Where the chat app is being served from. better-auth uses this to build
# correct redirect URLs. Defaults to VERCEL_URL or localhost.
# BETTER_AUTH_URL=https://playground.aura-llm.dev

# Postgres connection string for the playground_auth schema. Same DB as the
# Aura gateway (Fly Postgres). Use the public endpoint (not .flycast) since
# Vercel runs outside Fly's network.
# DATABASE_URL=postgres://...

# Aura gateway base URL. Defaults to https://api.aura-llm.dev.
# GATEWAY_BASE_URL=https://api.aura-llm.dev

# ============================================================================
# Reminder: restart the dev server after changing .env
# ============================================================================
# Vite and `vercel dev` only load .env on startup, not during hot-reload.
