# Aura LLM Gateway - Chat App Configuration
# Copy this file to .env and update with your values

# Aura Gateway URL (defaults to localhost:8080)
VITE_API_BASE_URL=http://localhost:8080

# Aura API Key for authentication
# Get your API key from: ./scripts/create_api_key.sh "my-chat-key"
# Or create via organization setup: ./scripts/setup_organization.sh
VITE_AURA_API_KEY=your-api-key-here

# Tavily API key for web search tool (optional)
# Get from: https://tavily.com
# VITE_TAVILY_API_KEY=tvly-xxxxxxxxxxxxx

# IMPORTANT: Restart the dev server after changing these values!
# Vite only loads .env on startup, not during hot-reload
